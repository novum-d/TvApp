#!/bin/bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "Running detekt check with Gradle..."

# staged Kotlin files がない場合は Gradle の detekt 実行を省略する
cachedFiles="$(
  git --no-pager diff \
    --diff-filter=d \
    --name-only \
    --cached
)"
echo -e "\n"
echo "Cached Files:"
echo "$cachedFiles"
echo -e "\n"

echo

# ktファイルのみ抽出
KOTLIN_INPUT=$(echo "$cachedFiles" | grep -E "\.kt$" || true)

# コマンド入力がない場合は、解析せずに正常終了
if [ -z "$KOTLIN_INPUT" ]; then
  echo "No Kotlin files to check. Skipping detekt."
  exit 0
fi

cd "$REPO_ROOT"

TEMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TEMP_DIR"' EXIT

BEFORE_FORMAT_DIFF="$TEMP_DIR/before-format.diff"
AFTER_FORMAT_DIFF="$TEMP_DIR/after-format.diff"

# 既存の unstaged 差分を保存しておく。
# staged と unstaged の両方に差分があるファイル(MM)でも、
# detektFormat が新しく変更しない限りコミットを許可する。
git --no-pager diff --binary -- $KOTLIN_INPUT > "$BEFORE_FORMAT_DIFF"

OUTPUT=$(./gradlew detektFormat detekt 2>&1) || {
  echo "***********************************************"
  echo "                 detekt failed                 "
  echo " Please fix the above issues before committing "
  echo "***********************************************"
  echo "$OUTPUT"
  exit 1
}

echo "$OUTPUT"

git --no-pager diff --binary -- $KOTLIN_INPUT > "$AFTER_FORMAT_DIFF"

if ! cmp -s "$BEFORE_FORMAT_DIFF" "$AFTER_FORMAT_DIFF"; then
  echo "***********************************************"
  echo "          detekt formatting changed files      "
  echo " Please review and stage formatted files first "
  echo "***********************************************"
  git --no-pager diff --name-only -- $KOTLIN_INPUT
  exit 1
fi

echo "detekt passed."
